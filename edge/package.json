{
  "name": "kyro-edge",
  "version": "0.0.0",
  "private": true,
  "description": "Kyro edge stream — offline on-device TBI decision co-pilot (E1–E7). Pre-scaffold; this package.json pins the seam-critical crypto (@noble) and tsx so the REAL shipping TS can be unit-tested before the RN scaffold exists.",
  "type": "module",
  "scripts": {
    "test": "node --experimental-sqlite --import tsx tests/run.ts ../cloud/bundles/edh-core-v0-mock.kyro",
    "demo": "node --experimental-sqlite --import tsx demo/runEncounter.ts ../cloud/bundles/edh-core-v0-mock.kyro",
    "demo:json": "node --experimental-sqlite --import tsx demo/runEncounter.ts ../cloud/bundles/edh-core-v0-mock.kyro --json",
    "demo:nodrop": "node --experimental-sqlite --import tsx demo/runEncounter.ts ../cloud/bundles/edh-core-v0-mock.kyro --no-drop",
    "demo:stable": "node --experimental-sqlite --import tsx demo/runEncounter.ts ../cloud/bundles/edh-core-v0-mock.kyro --case stable --no-drop",
    "demo:patch": "node --experimental-sqlite --import tsx demo/runEncounter.ts ../cloud/bundles/edh-core-v0-mock.kyro --case patch --no-drop",
    "demo:shock": "node --experimental-sqlite --import tsx demo/runEncounter.ts ../cloud/bundles/edh-core-v0-mock.kyro --case shock --no-drop",
    "demo:multilang": "node --experimental-sqlite --import tsx demo/runEncounter.ts ../cloud/bundles/edh-core-v0-mock.kyro --case stable --no-drop --lang all --model models/Qwen2.5-3B-Instruct-Q4_K_M.gguf",
    "demo:model": "node --experimental-sqlite --import tsx demo/runEncounter.ts ../cloud/bundles/edh-core-v0-mock.kyro --model models/Qwen2.5-3B-Instruct-Q4_K_M.gguf",
    "l3:validate": "node --import tsx l3/validateL3.ts",
    "parity": "node --experimental-sqlite --experimental-strip-types e1/parity.ts ../cloud/bundles/edh-core-v0-mock.kyro",
    "oracles:e2": "python e2/conformance.py",
    "oracles:e3": "python e3/conformance.py",
    "oracles:e4": "python e4/conformance.py",
    "oracles:e5": "python e5/conformance.py"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "node-llama-cpp": "^3.18.1",
    "nodejs-whisper": "^0.3.0"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  }
}
