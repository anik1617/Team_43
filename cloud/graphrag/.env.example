# Copy to cloud/graphrag/.env and fill in. GraphRAG reads these via ${VAR} in settings.yaml.

# --- COMPLETION (the part that matters: entity/relationship/community EXTRACTION) ---
# Use a cloud LLM API. OpenAI shown; for Claude/others point GRAPHRAG_API_BASE at an
# OpenAI-compatible gateway (e.g. LiteLLM proxy).
GRAPHRAG_API_KEY=sk-...
GRAPHRAG_MODEL=gpt-4.1
# GRAPHRAG_API_BASE=https://api.openai.com/v1     # override for a gateway / Azure / local

# --- EMBEDDINGS (DISCARDED — we re-embed with BGE-M3 in build_bundle.py) ---
# GraphRAG still needs an embedding model to finish indexing, but its vectors never ship.
# Use the cheapest available; anything OpenAI-compatible works.
GRAPHRAG_EMBEDDING_MODEL=text-embedding-3-small
