# dev signing private key — NEVER commit. The public key (dev_signer.pub) IS committed
# so the edge app can pin it.
keys/dev_signer.key

# secrets — never commit (each dev keeps their own)
.env

# throwaway compiler self-test artifact (regenerated by build_bundle --selftest)
bundles/edh-core-selftest.kyro

# GraphRAG run artifacts (regenerated by `graphrag index`)
graphrag/output/
graphrag/cache/
graphrag/logs/
graphrag/.env
graphrag/prompts/

__pycache__/
*.pyc
.venv/
venv/

# local model weights (GGUF, multi-GB) — never commit
models/
*.gguf

# generated harness artifacts (regenerate via python -m kyro_harness)
out/

# corpus text regenerated from the manifest by ingest/fetch_corpus.py (keep .gitkeep)
graphrag/input/*.txt

# copyrighted demo-only textbooks (Aniket-provided) — NEVER commit
ingest/textbooks/

# disposable Haiku dry-run graphrag root (config + subset corpus + output, all regenerable)
graphrag_dry/

# Kyro Cloud Service local SQLite DB + staged community contributions (regenerable)
service/*.db
ingest/contributions/

# disposable dry-run / dev artifacts (all regenerable; NOT device-parity)
# graphrag/settings.yaml is generated by `graphrag init`; settings.starter.yaml is the tracked template
graphrag/settings.yaml
graphrag/*.bak
# run report emitted by ingest/fetch_corpus.py
ingest/fetch_report.json
# 18MB HashEmbedder dry-run bundle — proved the pipeline, but not device-compatible (wrong embeddings)
bundles/edh-core-v99.kyro
